# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_USER=agencia_user
DB_PASSWORD=
DB_NAME=agencia_db

# Flask
SECRET_KEY=
FLASK_ENV=development
FLASK_DEBUG=False
APP_URL=http://localhost:8000

# Admin
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=

# Seguridad y cifrado
ENCRYPTION_KEY=
DNI_HASH_SALT=
DERIVED_KEY_SALT=

# CORS
CORS_ORIGINS=http://localhost:8000

# Redis y rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Duffel
DUFFEL_API_TOKEN=
DUFFEL_ACCOUNT_ID=
DUFFEL_PRIORITY_DELTA_PERCENT=5
AGENCY_MARKUP_PERCENT=5.0
SEARCH_RESULTS_LIMIT=10

# Amadeus
AMADEUS_ENABLED=false
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_DEFAULT_CURRENCY=EUR
AMADEUS_MAX_RESULTS=40

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Cache y calendario
CALENDAR_PRICE_CACHE_TTL_SECONDS=86400
CALENDAR_ENABLE_DAILY_REFRESH=true
CALENDAR_REFRESH_HOUR_UTC=3
CALENDAR_REFRESH_MINUTE_UTC=15
CALENDAR_PREWARM_ROUTES=
CALENDAR_PREWARM_TOP_ROUTES_LIMIT=40

# Feature flags
CHECKOUT_MULTI_STEP_ENABLED=true
CHECKOUT_MULTI_STEP_ROLLOUT_PERCENT=100

# Docker / herramientas
GRAFANA_ADMIN_PASSWORD=
PGADMIN_EMAIL=admin@agencia.local
PGADMIN_PASSWORD=

# Opcional: si quieres levantar stripe listen desde start_all.sh
START_STRIPE_LISTENER=false
