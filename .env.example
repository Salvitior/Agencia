# ============================================
# VARIABLES DE ENTORNO - COMPLETAS
# ============================================

# --- Base de Datos PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=          # OBLIGATORIO: contraseña de la BD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viatges_db

# --- Flask ---
SECRET_KEY=           # OBLIGATORIO en producción
FLASK_ENV=development
FLASK_DEBUG=False
APP_URL=http://localhost:8000

# --- Autenticación Admin ---
ADMIN_USER=admin
ADMIN_PASSWORD=       # OBLIGATORIO: contraseña del panel admin

# --- Cifrado ---
ENCRYPTION_KEY=       # OBLIGATORIO: clave Fernet para cifrar datos sensibles

# --- Seguridad (Hashing) ---
DNI_HASH_SALT=        # OBLIGATORIO: salt para hash de DNI (blind index)
DERIVED_KEY_SALT=     # OBLIGATORIO: salt para clave derivada legacy

# --- CORS ---
# Orígenes permitidos separados por coma. En producción, usar dominios reales.
CORS_ORIGINS=http://localhost:8000

# --- Duffel (Vuelos) ---
DUFFEL_API_TOKEN=     # Token de API de Duffel
DUFFEL_PRIORITY_DELTA_PERCENT=5
AGENCY_MARKUP_PERCENT=5.0
SEARCH_RESULTS_LIMIT=10

# --- Amadeus (opcional, deshabilitado por defecto) ---
AMADEUS_ENABLED=false
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_DEFAULT_CURRENCY=EUR
AMADEUS_MAX_RESULTS=40

# --- Stripe (Pagos legacy, opcional) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Caché y Calendario ---
CALENDAR_PRICE_CACHE_TTL_SECONDS=86400
CALENDAR_ENABLE_DAILY_REFRESH=true
CALENDAR_REFRESH_HOUR_UTC=3
CALENDAR_REFRESH_MINUTE_UTC=15
CALENDAR_PREWARM_ROUTES=
CALENDAR_PREWARM_TOP_ROUTES_LIMIT=40

# --- Feature Flags ---
CHECKOUT_MULTI_STEP_ENABLED=true
CHECKOUT_MULTI_STEP_ROLLOUT_PERCENT=100

# --- Docker (para docker-compose.yml) ---
GRAFANA_ADMIN_PASSWORD=   # Contraseña para Grafana
PGADMIN_EMAIL=admin@agencia.com
PGADMIN_PASSWORD=         # Contraseña para PgAdmin
